# ============================================================
# ModelBridge - 环境变量配置
# 复制此文件为 .env.local 并填写对应值
# ============================================================

# 数据库 (SQLite 本地开发 / Neon/Vercel Postgres 生产)
DATABASE_URL="file:./dev.db"
# 生产环境示例 (Neon Postgres):
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Session 加密密钥 (随机32位字符串，必填)
SESSION_SECRET="your-super-secret-session-key-change-this-32chars"

# 管理员账号 (首次部署后可在设置页修改)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123456"

# ── 默认预置模型 API (可选，留空则在控制台配置) ──────────────
DEFAULT_OPENAI_API_KEY=""
DEFAULT_OPENAI_BASE_URL="https://api.openai.com/v1"

DEFAULT_ANTHROPIC_API_KEY=""

DEFAULT_GEMINI_API_KEY=""
DEFAULT_GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# 站点信息
NEXT_PUBLIC_APP_NAME="ModelBridge"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
